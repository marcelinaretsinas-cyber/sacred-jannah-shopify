{% comment %}
  Sacred Jannah — 5 Day Eid Regenesis Retreat Page
  All content is editable from the Theme Editor (Customize) sidebar.
{% endcomment %}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700&family=PT+Serif:ital,wght@0,400;0,700;1,400&display=swap');

  .sj-root {
    --sj-gold: {{ section.settings.gold_color }};
    --sj-gold-light: {{ section.settings.gold_light_color }};
    --sj-off-white: {{ section.settings.off_white_color }};
    --sj-dark: {{ section.settings.dark_color }};
    --sj-muted: {{ section.settings.muted_color }};
    --sj-section-alt: {{ section.settings.section_alt_color }};
    --sj-border-gold: rgba(184,150,90,0.28);
    font-family: 'Cinzel', 'PT Serif', Georgia, serif;
    background: var(--sj-off-white);
    color: var(--sj-dark);
    min-height: 100vh;
    overflow-x: hidden;
  }
  .sj-root * { box-sizing: border-box; }

  .sj-gold-shimmer {
    background: linear-gradient(90deg, var(--sj-gold) 0%, var(--sj-gold-light) 40%, var(--sj-gold) 60%, #96733A 100%);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: sjShimmer 4s linear infinite;
  }
  @keyframes sjShimmer { 0% { background-position: 200% center; } 100% { background-position: -200% center; } }

  .sj-marquee-track { display: flex; animation: sjMarquee 35s linear infinite; white-space: nowrap; }
  @keyframes sjMarquee { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

  @keyframes sjGentleFloat { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }

  .sj-pillar-card { transition: all 0.4s cubic-bezier(0.4,0,0.2,1); }
  .sj-pillar-card:hover { transform: translateY(-8px); }

  .sj-nav-link {
    position: relative; text-decoration: none; transition: color 0.3s;
    font-size: 10px; letter-spacing: 0.2em; font-weight: 600;
    color: rgba(13,15,28,0.6); padding: 4px 0;
    font-family: Cinzel, serif;
  }
  .sj-nav-link::after {
    content: ''; position: absolute; bottom: 0; left: 0;
    width: 0; height: 1px; background: var(--sj-gold);
    transition: width 0.3s;
  }
  .sj-nav-link:hover { color: var(--sj-dark); }
  .sj-nav-link:hover::after { width: 100%; }

  .sj-cta-btn {
    display: inline-flex; align-items: center; gap: 8px;
    background: linear-gradient(135deg, var(--sj-gold), var(--sj-gold-light) 50%, var(--sj-gold));
    background-size: 200% auto;
    color: var(--sj-dark); border: none; cursor: pointer;
    padding: 14px 36px; border-radius: 100px;
    font-size: 11px; font-weight: 700; letter-spacing: 0.3em;
    font-family: Cinzel, serif;
    text-decoration: none;
    box-shadow: 0 8px 24px rgba(184,150,90,0.3);
    transition: all 0.4s ease;
  }
  .sj-cta-btn:hover { background-position: right center; transform: translateY(-2px); box-shadow: 0 12px 32px rgba(184,150,90,0.45); }

  .sj-cta-btn-outline {
    display: inline-flex; align-items: center; gap: 8px;
    background: transparent; color: var(--sj-dark);
    border: 1.5px solid var(--sj-gold); cursor: pointer;
    padding: 12px 34px; border-radius: 100px;
    font-size: 11px; font-weight: 700; letter-spacing: 0.3em;
    font-family: Cinzel, serif; text-decoration: none;
    transition: all 0.3s;
  }
  .sj-cta-btn-outline:hover { background: var(--sj-gold); color: white; }

  .sj-include-chip {
    display: inline-flex; align-items: center; gap: 8px;
    background: white; border: 1px solid rgba(184,150,90,0.2);
    border-radius: 100px; padding: 9px 18px; font-size: 11px;
    color: var(--sj-muted); font-family: Cinzel, serif;
    letter-spacing: 0.08em; box-shadow: 0 2px 8px rgba(13,15,28,0.04);
    transition: all 0.25s;
  }
  .sj-include-chip:hover { border-color: var(--sj-gold); color: var(--sj-dark); transform: translateY(-2px); }

  .sj-fade-in { opacity: 0; transform: translateY(24px); transition: opacity 0.8s cubic-bezier(0.4,0,0.2,1), transform 0.8s cubic-bezier(0.4,0,0.2,1); }
  .sj-fade-in.sj-visible { opacity: 1; transform: translateY(0); }

  .sj-section-label {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(184,150,90,0.1); border: 1px solid var(--sj-border-gold);
    border-radius: 100px; padding: 6px 18px;
    font-size: 10px; letter-spacing: 0.4em;
    color: var(--sj-gold); font-family: Cinzel, serif;
    font-weight: 600; margin-bottom: 20px;
  }
  .sj-section-label::before {
    content: ''; width: 4px; height: 4px; border-radius: 50%;
    background: var(--sj-gold); display: inline-block;
  }

  .sj-gold-divider {
    display: flex; align-items: center; gap: 10px;
    justify-content: center; padding: 6px 0;
  }
  .sj-gold-divider .sj-line {
    height: 1px; flex: 1; max-width: 100px;
  }

  .sj-services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .sj-pillars-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }

  @media (max-width: 768px) {
    .sj-services-grid, .sj-pillars-grid { grid-template-columns: 1fr; }
  }
</style>

<div class="sj-root">

  {% comment %} ── NAV ── {% endcomment %}
  <nav style="position: fixed; top: 0; left: 0; right: 0; z-index: 100; padding: 18px 32px; background: rgba(242,240,247,0.85); backdrop-filter: blur(18px); border-bottom: 1px solid rgba(184,150,90,0.12); display: flex; align-items: center; justify-content: space-between;">
    <a href="/" style="display: flex; align-items: center; gap: 10px; text-decoration: none;">
      <div style="width: 40px; height: 40px; border-radius: 50%; background: linear-gradient(135deg, var(--sj-gold), var(--sj-gold-light)); display: flex; align-items: center; justify-content: center;">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M14 3 C9 3 6 5.8 6 9 C6 12.2 9 15 14 15 C11.5 15 9 13.2 9 9 C9 4.8 11.5 3 14 3Z" fill="#0D0F1C" />
          <circle cx="3.5" cy="5.5" r="1" fill="#0D0F1C" fill-opacity="0.7" />
          <path d="M16.5 8 L17.5 10 L19.5 11 L17.5 12 L16.5 14 L15.5 12 L13.5 11 L15.5 10Z" fill="#0D0F1C" fill-opacity="0.6" />
        </svg>
      </div>
      <div>
        <div style="font-size: 9px; letter-spacing: 0.4em; color: var(--sj-gold); font-weight: 600;">{{ section.settings.brand_eyebrow }}</div>
        <div style="font-size: 18px; letter-spacing: 0.15em; font-weight: 700; color: var(--sj-dark);">{{ section.settings.brand_name }}</div>
      </div>
    </a>
    <div style="display: flex; align-items: center; gap: 32px;" class="sj-nav-links">
      {% for link in section.blocks %}
        {% if link.type == 'nav_link' %}
          <a href="{{ link.settings.url }}" class="sj-nav-link">{{ link.settings.label }}</a>
        {% endif %}
      {% endfor %}
      <a href="{{ section.settings.reserve_link }}" class="sj-cta-btn" style="padding: 10px 24px; font-size: 10px;">{{ section.settings.reserve_button_text }}</a>
    </div>
  </nav>

  {% comment %} ── HERO ── {% endcomment %}
  <section style="position: relative; min-height: 100vh; display: flex; align-items: center; justify-content: center; overflow: hidden; padding-top: 80px;">
    {% if section.settings.hero_image %}
      <img src="{{ section.settings.hero_image | image_url: width: 2000 }}" alt="{{ section.settings.hero_image.alt | escape }}" style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; filter: brightness(0.85);" />
    {% else %}
      <img src="{{ section.settings.hero_image_url }}" alt="Hero" style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; filter: brightness(0.85);" />
    {% endif %}
    <div style="position: absolute; inset: 0; background: linear-gradient(180deg, rgba(242,240,247,0.55) 0%, rgba(242,240,247,0.15) 45%, rgba(242,240,247,0.75) 85%, var(--sj-off-white) 100%);"></div>

    <div style="position: relative; text-align: center; padding: 0 24px; max-width: 880px;">
      <div class="sj-fade-in">
        <div class="sj-section-label">{{ section.settings.retreat_dates }}</div>
      </div>
      <div class="sj-fade-in" style="transition-delay: 0.15s;">
        <h1 style="font-size: clamp(48px, 8.5vw, 96px); line-height: 1.0; font-weight: 700; letter-spacing: 0.04em; margin-bottom: 12px;">
          <span class="sj-gold-shimmer">{{ section.settings.hero_title_line1 }}</span><br>
          <span style="color: var(--sj-dark);">{{ section.settings.hero_title_line2 }}</span>
        </h1>
      </div>
      <div class="sj-fade-in" style="transition-delay: 0.3s;">
        <div style="margin-top: 24px; margin-bottom: 44px;">
          <div class="sj-gold-divider">
            <div class="sj-line" style="background: linear-gradient(to right, transparent, var(--sj-border-gold));"></div>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 1L10.8 6.8H17L11.6 10.4L13.4 16.2L9 12.6L4.6 16.2L6.4 10.4L1 6.8H7.2L9 1Z" fill="{{ section.settings.gold_color }}" fill-opacity="0.4" stroke="{{ section.settings.gold_color }}" stroke-width="0.5"/></svg>
            <div class="sj-line" style="background: linear-gradient(to left, transparent, var(--sj-border-gold));"></div>
          </div>
          <p style="margin-top: 20px; font-size: 12px; letter-spacing: 0.35em; color: var(--sj-muted); font-family: 'PT Serif', serif;">{{ section.settings.hero_keywords }}</p>
        </div>
        <a href="{{ section.settings.reserve_link }}" class="sj-cta-btn">{{ section.settings.hero_cta_text }}</a>
      </div>
    </div>
  </section>

  {% comment %} ── SPIRITUAL AFFIRMATION ── {% endcomment %}
  <section style="background: var(--sj-dark); padding: 100px 32px; text-align: center; position: relative; overflow: hidden;">
    <div style="position: absolute; inset: 0; background: radial-gradient(ellipse at 50% 0%, rgba(184,150,90,0.1) 0%, transparent 65%); pointer-events: none;"></div>
    <div style="position: absolute; top: -120px; left: 50%; transform: translateX(-50%); width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(100,110,200,0.07) 0%, transparent 70%); pointer-events: none;"></div>

    <div style="position: relative; max-width: 780px; margin: 0 auto;">
      <div class="sj-fade-in">
        <div style="display: flex; align-items: center; justify-content: center; gap: 16px; margin-bottom: 40px;">
          <div style="height: 1px; width: 60px; background: linear-gradient(to right, transparent, rgba(184,150,90,0.5));"></div>
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <circle cx="10" cy="10" r="3" fill="{{ section.settings.gold_color }}" fill-opacity="0.5"/>
            <circle cx="10" cy="10" r="8" stroke="{{ section.settings.gold_color }}" stroke-width="0.6" stroke-opacity="0.3"/>
            <circle cx="10" cy="10" r="5.5" stroke="{{ section.settings.gold_color }}" stroke-width="0.4" stroke-opacity="0.2"/>
          </svg>
          <div style="height: 1px; width: 60px; background: linear-gradient(to left, transparent, rgba(184,150,90,0.5));"></div>
        </div>

        <p style="font-style: italic; font-size: clamp(18px, 3vw, 28px); color: rgba(242,240,247,0.9); letter-spacing: 0.03em; line-height: 1.85; font-family: 'PT Serif', serif; margin-bottom: 28px;">
          "{{ section.settings.spiritual_quote }}"
        </p>

        <div class="sj-gold-divider">
          <div class="sj-line" style="background: linear-gradient(to right, transparent, var(--sj-border-gold));"></div>
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 1L10.8 6.8H17L11.6 10.4L13.4 16.2L9 12.6L4.6 16.2L6.4 10.4L1 6.8H7.2L9 1Z" fill="{{ section.settings.gold_color }}" fill-opacity="0.4" stroke="{{ section.settings.gold_color }}" stroke-width="0.5"/></svg>
          <div class="sj-line" style="background: linear-gradient(to left, transparent, var(--sj-border-gold));"></div>
        </div>

        <p style="margin-top: 32px; font-size: 14.5px; color: rgba(242,240,247,0.5); font-family: 'PT Serif', serif; line-height: 2; max-width: 540px; margin-left: auto; margin-right: auto;">
          {{ section.settings.spiritual_supporting }}
        </p>

        <div style="display: flex; justify-content: center; gap: 48px; margin-top: 48px; flex-wrap: wrap;">
          {% for block in section.blocks %}
            {% if block.type == 'spiritual_pillar' %}
              <div style="text-align: center;">
                <div style="font-size: 18px; color: var(--sj-gold); opacity: 0.7; margin-bottom: 8px;">{{ block.settings.symbol }}</div>
                <div style="font-size: 9px; letter-spacing: 0.45em; color: rgba(184,150,90,0.55); font-family: Cinzel, serif; font-weight: 600;">{{ block.settings.label }}</div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </section>

  {% comment %} ── THREE PILLARS WITH VIDEO BACKGROUND ── {% endcomment %}
  <section style="position: relative; min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; overflow: hidden; padding: 100px 32px;">
    {% if section.settings.background_video_url != blank %}
      <video autoplay loop muted playsinline style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0;">
        <source src="{{ section.settings.background_video_url }}" type="video/mp4">
      </video>
    {% endif %}
    {% if section.settings.background_video_fallback %}
      <img src="{{ section.settings.background_video_fallback | image_url: width: 2000 }}" alt="Background" style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0;" />
    {% endif %}

    <div style="position: absolute; inset: 0; z-index: 1; background: linear-gradient(180deg, rgba(13,15,28,0.45) 0%, rgba(13,15,28,0.25) 35%, rgba(13,15,28,0.6) 75%, rgba(13,15,28,0.85) 100%); pointer-events: none;"></div>
    <div style="position: absolute; inset: 0; z-index: 1; background: radial-gradient(ellipse at 50% 60%, rgba(184,150,90,0.06) 0%, transparent 70%); pointer-events: none;"></div>

    <div style="position: relative; z-index: 2; max-width: 1100px; width: 100%; margin: 0 auto;">
      <div class="sj-fade-in">
        <div style="text-align: center; margin-bottom: 56px;">
          <div style="display: inline-flex; align-items: center; gap: 8px; background: rgba(184,150,90,0.15); border: 1px solid rgba(184,150,90,0.35); border-radius: 100px; padding: 6px 18px; font-size: 10px; letter-spacing: 0.4em; color: var(--sj-gold); font-family: Cinzel, serif; font-weight: 600; margin-bottom: 20px; backdrop-filter: blur(8px);">
            <span style="width: 4px; height: 4px; border-radius: 50%; background: var(--sj-gold); display: inline-block;"></span>
            {{ section.settings.pillars_eyebrow }}
          </div>
          <h2 style="font-size: clamp(32px, 5vw, 64px); font-weight: 700; letter-spacing: 0.04em; color: var(--sj-off-white); line-height: 1.1;">
            {{ section.settings.pillars_title_line1 }}<br>
            <span class="sj-gold-shimmer">{{ section.settings.pillars_title_line2 }}</span>
          </h2>
        </div>
      </div>

      <div class="sj-pillars-grid">
        {% assign pillar_index = 0 %}
        {% for block in section.blocks %}
          {% if block.type == 'pillar' %}
            {% assign is_middle = false %}
            {% if pillar_index == 1 %}{% assign is_middle = true %}{% endif %}
            <div class="sj-pillar-card sj-fade-in" style="background: {% if is_middle %}linear-gradient(160deg, rgba(184,150,90,0.22) 0%, rgba(184,150,90,0.08) 100%){% else %}rgba(13,15,28,0.45){% endif %}; backdrop-filter: blur(16px); border-radius: 20px; padding: 40px 28px; border: 1px solid {% if is_middle %}rgba(184,150,90,0.5){% else %}rgba(242,240,247,0.12){% endif %}; box-shadow: {% if is_middle %}0 16px 48px rgba(184,150,90,0.15){% else %}0 8px 32px rgba(0,0,0,0.3){% endif %}; position: relative; overflow: hidden; transition-delay: {{ pillar_index | times: 0.15 }}s;">
              {% if is_middle %}
                <div style="position: absolute; top: -40px; right: -40px; width: 140px; height: 140px; border-radius: 50%; background: radial-gradient(circle, rgba(184,150,90,0.2) 0%, transparent 70%); pointer-events: none;"></div>
              {% endif %}
              <div style="margin-bottom: 22px; animation: sjGentleFloat 4s ease-in-out infinite;">
                {% if block.settings.icon_svg != blank %}{{ block.settings.icon_svg }}{% endif %}
              </div>
              <div style="font-size: 9px; letter-spacing: 0.4em; color: rgba(184,150,90,0.8); margin-bottom: 8px; font-weight: 600;">{{ block.settings.subtitle }}</div>
              <h3 style="font-size: 19px; font-weight: 700; color: var(--sj-off-white); letter-spacing: 0.05em; margin-bottom: 14px;">{{ block.settings.title }}</h3>
              <div style="width: 32px; height: 2px; background: var(--sj-gold); border-radius: 2px; margin-bottom: 14px;"></div>
              <p style="font-size: 13px; line-height: 1.85; color: rgba(242,240,247,0.7); font-family: 'PT Serif', serif;">{{ block.settings.description }}</p>
            </div>
            {% assign pillar_index = pillar_index | plus: 1 %}
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>

  {% comment %} ── LOCATION ── {% endcomment %}
  <section style="position: relative; height: 500px; overflow: hidden;">
    {% if section.settings.location_image %}
      <img src="{{ section.settings.location_image | image_url: width: 2000 }}" alt="{{ section.settings.location_image.alt | escape }}" style="width: 100%; height: 100%; object-fit: cover; filter: brightness(0.48) saturate(0.7);" />
    {% else %}
      <img src="{{ section.settings.location_image_url }}" alt="Location" style="width: 100%; height: 100%; object-fit: cover; filter: brightness(0.48) saturate(0.7);" />
    {% endif %}
    <div style="position: absolute; inset: 0; background: linear-gradient(to top, rgba(13,15,28,0.7) 0%, transparent 60%);"></div>
    <div style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;">
      <div class="sj-fade-in">
        <div style="text-align: center; padding: 0 32px;">
          <div class="sj-section-label">{{ section.settings.location_eyebrow }}</div>
          <h2 style="font-size: clamp(30px, 5vw, 60px); font-weight: 700; color: var(--sj-off-white); letter-spacing: 0.04em; line-height: 1.1; margin-bottom: 20px;">
            {{ section.settings.location_title_line1 }}<br>{{ section.settings.location_title_line2 }}
          </h2>
          <p style="font-size: 15px; line-height: 1.9; color: rgba(242,240,247,0.75); font-family: 'PT Serif', serif; max-width: 560px; margin: 0 auto;">
            {{ section.settings.location_description }}
          </p>
        </div>
      </div>
    </div>
  </section>

  {% comment %} ── SERVICES / MODALITIES ── {% endcomment %}
  <section style="background: var(--sj-section-alt); padding: 100px 32px;">
    <div style="max-width: 1100px; margin: 0 auto;">
      <div class="sj-fade-in">
        <div style="text-align: center; margin-bottom: 64px;">
          <div class="sj-section-label">{{ section.settings.services_eyebrow }}</div>
          <h2 style="font-size: clamp(30px, 4.5vw, 52px); font-weight: 700; letter-spacing: 0.04em; color: var(--sj-dark); line-height: 1.15;">
            {{ section.settings.services_title_line1 }}<br><span style="color: var(--sj-muted);">{{ section.settings.services_title_line2 }}</span>
          </h2>
        </div>
      </div>

      <div class="sj-services-grid" style="margin-bottom: 60px;">
        {% for block in section.blocks %}
          {% if block.type == 'service' %}
            <div class="sj-fade-in" style="background: white; border-radius: 16px; padding: 32px 28px; box-shadow: 0 4px 20px rgba(13,15,28,0.05); border: 1px solid rgba(184,150,90,0.12); height: 100%;">
              <div style="display: inline-block; font-size: 10px; font-weight: 700; letter-spacing: 0.2em; color: var(--sj-gold); background: rgba(184,150,90,0.1); border: 1px solid var(--sj-border-gold); padding: 4px 12px; border-radius: 100px; margin-bottom: 20px;">{{ block.settings.tag }}</div>
              <h3 style="font-size: 15px; font-weight: 700; letter-spacing: 0.12em; color: var(--sj-dark); margin-bottom: 14px;">{{ block.settings.title }}</h3>
              <div style="width: 28px; height: 2px; background: var(--sj-gold); border-radius: 2px; margin-bottom: 14px;"></div>
              <p style="font-size: 13.5px; line-height: 1.85; color: var(--sj-muted); font-family: 'PT Serif', serif;">{{ block.settings.description }}</p>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>

  {% comment %} ── MARQUEE ── {% endcomment %}
  <div style="background: var(--sj-dark); padding: 14px 0; overflow: hidden; border-top: 1px solid rgba(184,150,90,0.15); border-bottom: 1px solid rgba(184,150,90,0.15);">
    <div class="sj-marquee-track">
      {% for i in (1..2) %}
        <div style="display: flex; gap: 40px; padding-right: 40px;">
          {% for block in section.blocks %}
            {% if block.type == 'marquee_item' %}
              <span style="font-size: 10px; letter-spacing: 0.35em; color: rgba(184,150,90,0.65); white-space: nowrap; font-family: Cinzel, serif; font-weight: 600;">✦ &nbsp; {{ block.settings.text }}</span>
            {% endif %}
          {% endfor %}
        </div>
      {% endfor %}
    </div>
  </div>

  {% comment %} ── INCLUDED & PRICING ── {% endcomment %}
  <section id="register" style="background: var(--sj-off-white); padding: 100px 32px;">
    <div style="max-width: 1100px; margin: 0 auto;">
      <div class="sj-fade-in">
        <div style="text-align: center; margin-bottom: 64px;">
          <div class="sj-section-label">{{ section.settings.included_eyebrow }}</div>
          <h2 style="font-size: clamp(30px, 4.5vw, 52px); font-weight: 700; color: var(--sj-dark); letter-spacing: 0.04em;">
            {{ section.settings.included_title_line1 }}<br><span class="sj-gold-shimmer">{{ section.settings.included_title_line2 }}</span>
          </h2>
        </div>
      </div>

      <div class="sj-fade-in">
        <div style="display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; margin-bottom: 56px;">
          {% for block in section.blocks %}
            {% if block.type == 'included_item' %}
              <div class="sj-include-chip">
                <span style="width: 5px; height: 5px; border-radius: 50%; background: var(--sj-gold); display: inline-block; flex-shrink: 0;"></span>
                {{ block.settings.text }}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>

      <div class="sj-fade-in">
        <div style="text-align: center;">
          <p style="font-size: 11px; letter-spacing: 0.3em; color: rgba(107,112,128,0.6); margin-bottom: 24px;">{{ section.settings.pricing_eyebrow }}</p>
          <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
            <a href="{{ section.settings.pay_full_link }}" class="sj-cta-btn">{{ section.settings.pay_full_text }}</a>
            <a href="{{ section.settings.pay_installments_link }}" class="sj-cta-btn-outline">{{ section.settings.pay_installments_text }}</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  {% comment %} ── FOOTER ── {% endcomment %}
  <footer style="background: var(--sj-dark); border-top: 1px solid rgba(184,150,90,0.1); padding: 52px 32px; text-align: center;">
    <div style="display: flex; align-items: center; justify-content: center; gap: 10px; margin-bottom: 20px;">
      <div style="width: 40px; height: 40px; border-radius: 50%; background: linear-gradient(135deg, var(--sj-gold), var(--sj-gold-light)); display: flex; align-items: center; justify-content: center;">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M14 3 C9 3 6 5.8 6 9 C6 12.2 9 15 14 15 C11.5 15 9 13.2 9 9 C9 4.8 11.5 3 14 3Z" fill="#0D0F1C" />
          <circle cx="3.5" cy="5.5" r="1" fill="#0D0F1C" fill-opacity="0.7" />
          <path d="M16.5 8 L17.5 10 L19.5 11 L17.5 12 L16.5 14 L15.5 12 L13.5 11 L15.5 10Z" fill="#0D0F1C" fill-opacity="0.6" />
        </svg>
      </div>
      <div>
        <div style="font-size: 9px; letter-spacing: 0.4em; color: var(--sj-gold); font-weight: 600;">{{ section.settings.brand_eyebrow }}</div>
        <div style="font-size: 18px; letter-spacing: 0.15em; font-weight: 700; color: var(--sj-off-white);">{{ section.settings.brand_name }}</div>
      </div>
    </div>
    <p style="margin-top: 24px; font-size: 10px; letter-spacing: 0.25em; color: rgba(242,240,247,0.3); font-family: 'PT Serif', serif;">
      {{ section.settings.footer_tagline }}
    </p>
    <p style="margin-top: 10px; font-size: 9px; color: rgba(242,240,247,0.15); letter-spacing: 0.15em;">
      {{ section.settings.footer_copyright }}
    </p>
  </footer>

</div>

<script>
  (function() {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('sj-visible');
        }
      });
    }, { threshold: 0.12 });
    document.querySelectorAll('.sj-fade-in').forEach(function(el) { observer.observe(el); });
  })();
</script>

